# Remove samples with >5% missing genotypes
plink --vcf step1_biallelic_snps.vcf.gz --missing --out sample_missingness
awk '$6 > 0.05 {print $1, $2}' sample_missingness.imiss > remove_samples.txt
if [ -s remove_samples.txt ]; then
  plink --vcf step1_biallelic_snps.vcf.gz \
    --remove remove_samples.txt \
    --recode vcf bgz --out step2_samples_filtered
else
  cp step1_biallelic_snps.vcf.gz step2_samples_filtered.vcf.gz
  bcftools index -t step2_samples_filtered.vcf.gz
fi

# Remove variants failing Hardy-Weinberg equilibrium (HWE)
plink --vcf step2_samples_filtered.vcf.gz --hardy --out hwe_check
awk '$9 < 1e-6 {print $1, $2}' hwe_check.hwe > remove_hwe.txt
if [ -s remove_hwe.txt ]; then
  plink --vcf step2_samples_filtered.vcf.gz \
    --exclude remove_hwe.txt \
    --recode vcf bgz --out step3_hwe_filtered
else
  cp step2_samples_filtered.vcf.gz step3_hwe_filtered.vcf.gz
  bcftools index -t step3_hwe_filtered.vcf.gz
fi

# Create final PLINK binary files for GWAS
plink --vcf step3_hwe_filtered.vcf.gz \
